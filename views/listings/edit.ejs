<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="col-8 offset-2">

            <h3>Edit your Listing</h3>
            <form method="post" action="/listings/<%= listing._id %>?_method=PUT">

                <div class="mb-3">
                    <lable for="title" class="form-label">Title</lable>
                    <input type="text" name="listing[title]" class="form-control" value="<%= listing.title %>">
                </div>

                <div class="mb-3">
                    <lable for="Description" class="form-label">Description</lable>
                    <textarea name="listing[description]" class="form-control"><%= listing.description %></textarea>
                </div>


                <div class="mb-3">
                    <lable for="image" class="form-label">Image Link</lable>
                    <input type="text" name="listing[image]" class="form-control" value="<%= listing.image %>">
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <lable for="price" class="form-label">Price</lable>
                        <input type="number" name="listing[price]" class="form-control" value="<%= listing.price %>">
                    </div>

                    <div class="mb-3 col-md-8">
                        <lable for="country" class="form-label">Country</lable>
                        <input type="text" name="listing[country]" class="form-control" value="<%= listing.country %>">
                    </div>
                </div>

                <div class="mb-3">
                    <lable for="location" class="form-label">Location</lable>
                    <input type="text" name="listing[location]" class="form-control" value="<%= listing.location %>">
                </div>

                <button class="btn btn-dark edit-btn mt-3">Edit</button>
            </form>
        </div>
    </div>